{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "/Applications/Caff.app/Contents/MacOS/Caff agent-touch --source claude --cooldown-seconds 1800",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/Applications/Caff.app/Contents/MacOS/Caff agent-touch --source claude --cooldown-seconds 1800",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "/Applications/Caff.app/Contents/MacOS/Caff agent-touch --source claude --cooldown-seconds 1800",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "/Applications/Caff.app/Contents/MacOS/Caff agent-touch --source claude --cooldown-seconds 1800",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  }
}
